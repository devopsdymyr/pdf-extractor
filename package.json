{
  "name": "pdfextractor",
  "publisher": "kathirvel-labs",
  "displayName": "PDF Extractor",
  "description": "Extract text from PDF files directly from the VS Code Explorer context menu.",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devopsdymyr/pdf-extractor.git"
  },
  "homepage": "https://github.com/devopsdymyr/pdf-extractor#readme",
  "bugs": {
    "url": "https://github.com/devopsdymyr/pdf-extractor/issues"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "keywords": [
    "pdf",
    "extract",
    "text",
    "pdf-parser",
    "document"
  ],
  "categories": [
    "Other",
    "Productivity"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pdfExtractor.extract",
        "title": "Extract Text from PDF"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "pdfExtractor.extract",
          "when": "resourceExtname == .pdf",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1"
  }
}
